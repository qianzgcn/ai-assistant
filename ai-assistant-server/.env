# AI Assistant Server Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Required
# =============================================================================

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# Optional - Server Configuration
# =============================================================================

# OpenAI API Base URL (default: https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1

# Default AI Model (default: gpt-4o-mini)
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# CORS Origins - comma-separated list of allowed origins
# Use * for all origins (not recommended for production)
CORS_ORIGINS=*

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Debug Mode (true/false)
DEBUG=false

# =============================================================================
# Optional - Available Models
# =============================================================================

# JSON array of available models
# AVAILABLE_MODELS=[{"id":"gpt-4o","name":"GPT-4o","description":"..."}]
